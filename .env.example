# Hipp0 Environment Configuration
# Copy to .env and fill in values
# docker-compose reads this file automatically

#  Docker / PostgreSQL ─
POSTGRES_USER=hipp0
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=hipp0
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_SSL=false

#  Server 
# ⚠️ Change NODE_ENV to 'development' only for local dev
NODE_ENV=production
PORT=3100

#  Dashboard ─
# Leave empty — nginx proxies /api/ to the server container.
# Never set to an absolute URL (http://...) in Docker.
VITE_API_URL=""

#  AI / Distillery ─
# Required for distillery (decision extraction from conversations)
ANTHROPIC_API_KEY=sk-ant-your-key-here
DISTILLERY_PROVIDER=anthropic
HIPP0_LLM_MODEL=claude-opus-4-6

#  Embeddings (optional)
# Enables semantic similarity scoring in context compilation.
# Without this, the semantic_similarity signal is always 0.
# OPENAI_API_KEY=sk-your-key-here
#
# HIPP0_EMBEDDING_PROVIDER selects where vectors come from:
#   openai  → text-embedding-3-small (1536 dims, best quality, needs OPENAI_API_KEY)
#   local   → Xenova/all-MiniLM-L6-v2 via @xenova/transformers (384 dims, offline)
#   auto    → Prefer OpenAI when a key is set, fall back to local
# The local provider downloads ~90MB to /tmp/hipp0-models on first use.
# HIPP0_EMBEDDING_PROVIDER=auto

#  Security 
# API keys are auto-generated per project on first startup.

# Trust X-Forwarded-For header (set true when behind a reverse proxy)
# HIPP0_TRUSTED_PROXY=false

# Store raw task descriptions (default: false, stores SHA256 hash only)
# HIPP0_STORE_RAW_TASKS=false

#  Phase 3: Supabase Auth ─
# Required when HIPP0_AUTH_REQUIRED=true
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

#  Phase 3: Auth Feature Flag ─
# Auth enforcement. Always true in production (NODE_ENV=production).
# Defaults to true in development. Set false for local dev without API keys.
HIPP0_AUTH_REQUIRED=true

#  CORS (production only) ─
# Dev mode allows all origins. In production, list allowed origins:
# hipp0.ai and localhost:3200 are always included.
# HIPP0_CORS_ORIGINS=http://localhost:3200,https://yourdomain.com

#  Phase 6: Stripe Billing 
# Required for monetization features (Checkout, Portal, Webhooks)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# Dashboard URL for Stripe redirect callbacks
# DASHBOARD_URL=http://localhost:3200

#  Auto-discovery (optional) 
# HIPP0_OPENCLAW_PATH=/path/to/openclaw/workspace
# HIPP0_WATCH_DIR=/path/to/watch

#  Redis / Job Queue (optional) ─
# When set, ingestion uses BullMQ job queues for reliability + rate limiting.
# When not set, ingestion still works but processes inline (no queue).
# HIPP0_REDIS_URL=redis://redis:6379

#  Telegram Bot Ingestion (optional) 
# Bot token from @BotFather
# HIPP0_TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs to listen in (empty = all chats)
# HIPP0_TELEGRAM_CHAT_IDS=
# Default project ID for ingested decisions
# HIPP0_TELEGRAM_PROJECT_ID=
# Whether to reply with confirmation (default: true)
# HIPP0_INGEST_REPLY_ENABLED=true

#  OpenClaw Auto-Discovery (optional) ─
#
# Two features both read from the same OpenClaw workspace root:
#
#   1. Continuous watcher — polls for session-*.jsonl files and
#      streams them into the Distillery queue (set HIPP0_OPENCLAW_PATH).
#   2. One-shot markdown import — POST /api/projects/:id/openclaw/import
#      walks workspace-*/ dirs for *.md artifacts (audit reports,
#      reviews, specs) and submits each to the Distillery.
#
# To enable the one-shot import (recommended for initial backfill):
#   a. Set HIPP0_OPENCLAW_HOST_PATH below to the HOST-side path of
#      your OpenClaw data directory containing workspace-* subdirs.
#   b. Rebuild the server: docker compose up -d --force-recreate server
#   c. Trigger: curl -sS -X POST \\
#        http://localhost:3100/api/projects/<PROJECT_UUID>/openclaw/import \\
#        -H "Content-Type: application/json" -d '{}'
#
# HIPP0_OPENCLAW_HOST_PATH is read by docker-compose.yml to bind-mount
# the host directory into /openclaw inside the server container.
# If unset, /openclaw is a no-op mount and the import endpoint safely
# returns "no workspaces found".
#
# HIPP0_OPENCLAW_HOST_PATH=/docker/openclaw-okny/data/.openclaw
# HIPP0_DEFAULT_PROJECT_ID=44c6cebd-b6ff-47b7-ad93-52925bf26eb0
# HIPP0_OPENCLAW_PROJECT_ID=
# Alternative: any directory with .jsonl files (for the watcher)
# HIPP0_WATCH_DIR=

#  GitHub Deep Integration (optional) ─
# GitHub App credentials for bidirectional PR↔decision linking
# HIPP0_GITHUB_APP_ID=
# PEM format, base64 encoded (base64 -w 0 < key.pem)
# HIPP0_GITHUB_APP_PRIVATE_KEY=
# From app installation page
# HIPP0_GITHUB_APP_INSTALLATION_ID=
# HMAC secret for webhook signature verification
# HIPP0_GITHUB_WEBHOOK_SECRET=
# Default project for PR decisions (falls back to HIPP0_DEFAULT_PROJECT_ID)
# HIPP0_GITHUB_PROJECT_ID=
# Which Hipp0 project to link PRs to
# HIPP0_GITHUB_DEFAULT_PROJECT_ID=
# Dashboard URL for PR comment links
# HIPP0_DASHBOARD_URL=http://localhost:3200

#  Discord Bot (optional) ─
# Bot token from Discord Developer Portal
# HIPP0_DISCORD_BOT_TOKEN=
# Default project ID for ingested decisions
# HIPP0_DISCORD_PROJECT_ID=
# Comma-separated guild IDs to listen in (empty = all guilds)
# HIPP0_DISCORD_GUILD_IDS=
# Comma-separated channel IDs to listen in (empty = all channels)
# HIPP0_DISCORD_CHANNEL_IDS=

#  Slack Integration (optional) ─
# Slack signing secret from app settings (for webhook verification)
# HIPP0_SLACK_SIGNING_SECRET=
# Default project ID for ingested decisions
# HIPP0_SLACK_PROJECT_ID=
# Comma-separated channel IDs to listen in (empty = all channels)
# HIPP0_SLACK_CHANNEL_IDS=

#  Phase 7: Redis Caching (optional) ─
# When set, uses Redis for caching compile results, stats, and agent lists.
# When not set, falls back to in-memory cache.
# REDIS_URL=redis://localhost:6379

#  Phase 7: Sentry Error Tracking (optional) ─
# When set, initializes Sentry for error tracking and performance monitoring.
# SENTRY_DSN=

#  Linear Integration (optional) ─
# OAuth app credentials from Linear Settings > API > Applications
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# LINEAR_WEBHOOK_SECRET=
# LINEAR_REDIRECT_URI=http://localhost:3200/api/linear/callback

#  Phase 7: Logging 
# Minimum log level for structured JSON logger (debug, info, warn, error)
# LOG_LEVEL=info

#  Digest Delivery — SMTP for email digests ─
# Used by the weekly memory digest delivery pipeline to send HTML emails.
# Configured per-project in the `digest_delivery_config` table; these env
# vars are the fallback defaults when a project row omits SMTP settings.
HIPP0_SMTP_HOST=
HIPP0_SMTP_PORT=587
HIPP0_SMTP_USER=
HIPP0_SMTP_PASS=
HIPP0_SMTP_FROM=noreply@hipp0.ai

#  Cost tracking & budget caps ─
# Track LLM spend per project and optionally cap daily spend. Every call the
# distillery makes is recorded in the `llm_usage` table with a computed USD
# cost. When a cap is hit, new distillery extractions are skipped (not
# failed) so the rest of the pipeline keeps working.
HIPP0_DAILY_BUDGET_USD=           # Optional per-project daily cap (empty = unlimited)
HIPP0_COST_ALERTS_WEBHOOK=        # Optional webhook for cost alerts

#  OpenTelemetry observability ─
# Export traces and metrics over OTLP/HTTP to Datadog, Grafana Tempo/Mimir,
# Honeycomb, the OpenTelemetry Collector, or any OTLP-compatible backend.
# When HIPP0_TELEMETRY_ENABLED is not 'true', all telemetry is a no-op.
HIPP0_TELEMETRY_ENABLED=false
HIPP0_OTLP_ENDPOINT=http://localhost:4318
HIPP0_OTEL_SERVICE_NAME=hipp0-server
HIPP0_OTEL_SERVICE_VERSION=0.1.1

#  Background workers (optional) ─
# Scheduled reflection worker runs hourly/daily/weekly reflection loops for
# every active project with no cron setup. Leave 'false' if you call
# /api/projects/:id/reflect yourself.
HIPP0_SCHEDULER_ENABLED=false

#  Hosted playground (optional) ─
# Exposes /api/playground/* routes — ephemeral sandboxed SQLite sessions with
# 50 pre-seeded decisions and 5 canned scenarios. Safe to leave off in
# production unless you run hipp0.ai/playground yourself.
HIPP0_PLAYGROUND_ENABLED=false

#  Cross-project pattern sharing (optional) ─
# When 'true', patterns discovered in this project are anonymized and shared
# back to the community pattern pool. Per-project opt-in via the UI also
# works; this env var is a global default.
# HIPP0_SHARE_PATTERNS=false
